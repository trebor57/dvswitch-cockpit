# DVSwitch Cockpit service-restart permissions
# Copy to:
#   /etc/sudoers.d/dvswitch-cockpit-services
#
# Validate with:
#   sudo visudo -cf /etc/sudoers.d/dvswitch-cockpit-services
#
# The systemctl commands match api/service_action.php exactly.
# The asterisk read-only command lets runtime_status.php verify whether
# the private DVSwitch audio node is linked for TGIF/HBLink status detection.

www-data ALL=(root) NOPASSWD: /usr/bin/systemctl restart analog_bridge.service, /usr/bin/systemctl restart mmdvm_bridge.service, /usr/sbin/asterisk -rx rpt nodes *
